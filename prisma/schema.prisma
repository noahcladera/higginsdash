// People
enum RoleInHousehold {
  adult
  child

  @@map("role_in_household")
}

enum Gender {
  male
  female
  other
  prefer_not_to_say

  @@map("gender")
}

enum EmailKind {
  personal
  work
  other

  @@map("email_kind")
}

enum SkillLevel {
  // Tenniskids progression (kids)
  red_1
  red_2
  red_3
  orange_1
  orange_2
  orange_3
  green_1
  green_2
  yellow

  // Adult recreational buckets
  adult_beginner_beginner
  adult_beginner_intermediate
  adult_advanced_beginner
  adult_intermediate
  adult_advanced

  @@map("skill_level")
}

/// Audience for CMS-style level descriptions (kids Tenniskids vs adult buckets).
enum LevelAudience {
  kids
  adults

  @@map("level_audience")
}

enum StudentEnrollmentStatus {
  active
  paused
  archived

  @@map("student_enrollment_status")
}

enum CoachEmploymentType {
  employee
  freelancer

  @@map("coach_employment_type")
}

/// Admin-generated coach onboarding invite (staff vs ZZP).
enum CoachInviteRole {
  staff_coach
  zzp_coach

  @@map("coach_invite_role")
}

// Physical infrastructure
enum ClubOwnershipType {
  owned
  leased
  shared

  @@map("club_ownership_type")
}

enum CourtSurface {
  clay
  grass
  multi_use
  hard
  indoor_hard
  other

