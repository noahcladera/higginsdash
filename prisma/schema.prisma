// Higgins Tennis NL — database schema
// Source-of-truth: design/database.md (the conceptual model; note the schema has
// since grown to 55 models / 57 enums as the product expanded — keep design.md in sync)
//
// Conventions:
// - DB column / table names are snake_case (matches design/database.md 1:1)
// - Prisma client uses camelCase (Prisma idiom)
// - Mapping is via @map / @@map on every renamed identifier
// - All UUIDs use Postgres native uuid type
// - All timestamps use timestamptz (UTC at rest, rendered in Europe/Amsterdam at the display layer per R-cross-cutting)
//
// Postgres-only features that Prisma cannot express are added via a hand-edited
// follow-up migration (see prisma/migrations/<timestamp>_postgres_extras/migration.sql):
//   - btree_gist extension
//   - tstzrange `during` generated column on court_bookings
//   - EXCLUDE constraint on court_bookings (R13 conflict prevention)
//   - Partial unique index on email_addresses (one primary email per person)
//
// people.id == auth.users.id (Supabase) — no separate auth bridge column.
// On first login, a people row is auto-created with id = supabase auth user id.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

