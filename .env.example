# Copy to `.env.local` and fill in real values (never commit `.env.local`).

# Supabase (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Postgres (Settings → Database → connection strings)
DATABASE_URL=
DIRECT_URL=

# Public site origin — must match the URL you type in the browser for magic links.
# Local dev:
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Render production (example — set the same value in Render Environment, then redeploy):
# NEXT_PUBLIC_SITE_URL=https://higginsdash.onrender.com

# Comma-separated admin emails allowed to clear org profile locks (preset / terminology).
PLATFORM_SUPPORT_EMAILS=

# Comma-separated emails that may become admin on first login (empty DB only).
# Production example: play@higginstennis.nl
PLATFORM_ADMIN_EMAILS=

# --- Payments (Mollie) ---
# When both are set, checkouts use real Mollie hosted payments + webhooks.
# Use Mollie *test* API keys on staging first.
MOLLIE_API_KEY_TRIAZ=
MOLLIE_API_KEY_HIGGINS=

# Set to "false" in production when Mollie is live (blocks /demo/mollie routes).
NEXT_PUBLIC_DEMO_MOLLIE=

# --- Email (Resend) ---
# Required for coach invite autosend, booking receipts, and private-lesson invoices.
# Without RESEND_API_KEY, admins must copy magic links manually from Coaches → Pending invites.
# On Render: add RESEND_API_KEY + EMAIL_FROM, then resend an invite (no redeploy needed).
# Verify higginstennis.nl (or your sender domain) in the Resend dashboard before production.
RESEND_API_KEY=
EMAIL_FROM=Higgins Tennis <noreply@higginstennis.nl>

# --- Rate limiting (Upstash Redis) ---
# Protects login, signup, the public trial form, and the Mollie webhook from
# brute force / abuse. Create a free Upstash Redis DB and paste the REST creds.
# If unset, rate limiting is DISABLED (fails open) — set these before production.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
